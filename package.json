{
  "name": "laminaria",
  "version": "0.1.0",
  "private": true,
  "description": "Laminaria — calm, human webinar infrastructure for global teams.",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @laminaria/web --filter @laminaria/api --filter @laminaria/worker dev",
    "dev:web": "pnpm --filter @laminaria/web dev",
    "dev:api": "pnpm --filter @laminaria/api dev",
    "dev:worker": "pnpm --filter @laminaria/worker dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:run": "pnpm -r --if-present test:run",
    "check": "pnpm lint && pnpm typecheck && pnpm test:run && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:bootstrap": "node scripts/dev-db-bootstrap.cjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "infra:up": "docker compose up -d postgres redis minio mailpit",
    "infra:down": "docker compose down",
    "clean": "pnpm -r --if-present clean"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
