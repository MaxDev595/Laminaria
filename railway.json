{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm db:generate && pnpm --filter @laminaria/api build"
  },
  "deploy": {
    "startCommand": "pnpm db:deploy && pnpm --filter @laminaria/api start",
    "healthcheckPath": "/health/live",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
