# Public URLs
WEB_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000
NEXT_PUBLIC_LIVEKIT_URL=

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://laminaria:laminaria-local@localhost:5432/laminaria?schema=public
POSTGRES_USER=laminaria
POSTGRES_PASSWORD=laminaria-local
POSTGRES_DB=laminaria

# Session-token protection — replace before any shared deployment
TOKEN_PEPPER=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=laminaria_session
SESSION_TTL_SECONDS=2592000
SESSION_IDLE_TTL_SECONDS=604800
CSRF_COOKIE_NAME=laminaria_csrf
COOKIE_DOMAIN=
SKIP_EMAIL_VERIFICATION=true

# Realtime and queues
REDIS_URL=redis://localhost:6379

# LiveKit Cloud or self-hosted LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_SECRET=

# S3-compatible object storage
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Email delivery. Mailpit is available locally on port 8025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Laminaria <noreply@localhost>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# AI adapter. Keep disabled until a real provider and key are selected.
AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=

# Billing adapter. Prices and provider require a business decision.
BILLING_PROVIDER=disabled
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
