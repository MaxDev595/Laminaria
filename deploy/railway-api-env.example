NODE_ENV=production
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=true

PUBLIC_API_URL=https://your-api-domain.up.railway.app
WEB_APP_URL=https://your-vercel-domain.vercel.app
CORS_ORIGINS=https://your-vercel-domain.vercel.app

DATABASE_URL=replace-with-railway-postgres-database-url
TOKEN_PEPPER=replace-with-a-random-string-at-least-32-characters-long

SESSION_COOKIE_NAME=laminaria_session
SESSION_TTL_SECONDS=2592000
SESSION_IDLE_TTL_SECONDS=604800
CSRF_COOKIE_NAME=laminaria_csrf
SKIP_EMAIL_VERIFICATION=true


LIVEKIT_URL=https://your-livekit-domain.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_TOKEN_TTL_SECONDS=300

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=

BILLING_PROVIDER=disabled
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
