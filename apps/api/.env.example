# Runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=4000
LOG_LEVEL=info
TRUST_PROXY=false
PUBLIC_API_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL / session security
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/laminaria?schema=public
SESSION_COOKIE_NAME=laminaria_session
SESSION_TTL_SECONDS=2592000
SESSION_IDLE_TTL_SECONDS=604800
CSRF_COOKIE_NAME=laminaria_csrf
TOKEN_PEPPER=replace-with-at-least-32-random-characters
SKIP_EMAIL_VERIFICATION=false

# LiveKit (required only for media token issuance)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=300

# SMTP mail. The local Docker stack exposes Mailpit on port 1025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Laminaria <noreply@localhost>
PHONE_AUTH_DEV_CODE=000000

# Google OAuth (free to create in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback

# AI
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# Billing
BILLING_PROVIDER=
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

# S3-compatible object storage
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
