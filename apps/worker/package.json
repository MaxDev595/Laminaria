{
  "name": "@laminaria/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1084.0",
    "bullmq": "5.80.0",
    "dotenv": "17.4.2",
    "ioredis": "5.10.1",
    "nodemailer": "9.0.3",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/nodemailer": "8.0.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
